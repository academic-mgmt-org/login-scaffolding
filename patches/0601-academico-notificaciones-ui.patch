+<?php
+
+namespace App\Http\Controllers;
+
+use App\Contracts\AcademicGateway;
+use App\Exceptions\AcademicGatewayException;
+use Illuminate\Http\RedirectResponse;
+use Illuminate\Http\Request;
+use Illuminate\Support\Carbon;
+use Illuminate\Support\Facades\Log;
+use Illuminate\Support\Str;
+use Illuminate\View\View;
+use Throwable;
+
+final class AcademicNotificationController extends Controller
+{
+    private const LIST_RPC = 'notificaciones.v1.NotificationService/ListNotifications';
+
+    private const MARK_READ_RPC = 'notificaciones.v1.NotificationService/MarkAsRead';
+
+    private const MARK_ALL_READ_RPC = 'notificaciones.v1.NotificationService/MarkAllAsRead';
+
+    public function __construct(private readonly AcademicGateway $gateway) {}
+
+    /** @param  array<string, mixed>  $module */
+    public function index(Request $request, array $module): View
+    {
+        $identity = $this->identity($request);
+        $state = (string) $request->query('estado', '');
+        $state = in_array($state, ['no_leido', 'leido', 'archivado'], true) ? $state : '';
+        $search = Str::limit(trim((string) $request->query('buscar', '')), 100, '');
+        $notifications = collect();
+        $unreadCount = 0;
+        $loadError = null;
+
+        try {
+            $payload = [
+                'usuario_id' => $identity['user_id'],
+                'limit' => 50,
+            ];
+
+            if ($state !== '') {
+                $payload['estado'] = $state;
+            }
+
+            $result = $this->gateway->invoke(self::LIST_RPC, $payload, $this->accessToken($request));
+            $items = $result['notifications'] ?? [];
+            $items = is_array($items) ? $items : [];
+            $notifications = collect($items)
+                ->map(fn (mixed $notification): ?array => $this->normalize($notification))
+                ->filter()
+                ->values();
+            $unreadCount = (int) ($result['unreadCount'] ?? $notifications->where('unread', true)->count());
+        } catch (AcademicGatewayException $exception) {
+            Log::warning('Notification inbox could not be loaded.', [
+                'status_code' => $exception->statusCode,
+                'rpc' => $exception->rpc,
+            ]);
+            $loadError = $this->friendlyStatus($exception);
+        }
+
+        $listedCount = $notifications->count();
+
+        if ($search !== '') {
+            $needle = Str::lower($search);
+            $notifications = $notifications
+                ->filter(static fn (array $notification): bool => Str::contains(
+                    Str::lower($notification['title'].' '.$notification['message']),
+                    $needle,
+                ))
+                ->values();
+        }
+
+        return view('academic-interface::notifications', [
+            'module' => $module,
+            'identity' => $identity,
+            'displayName' => $this->displayName($identity),
+            'displayRole' => $this->displayRole($identity['role']),
+            'notifications' => $notifications,
+            'unreadCount' => $unreadCount,
+            'listedCount' => $listedCount,
+            'state' => $state,
+            'search' => $search,
+            'loadError' => $loadError,
+        ]);
+    }
+
+    public function markAsRead(Request $request, string $notification): RedirectResponse
+    {
+        try {
+            $this->gateway->invoke(self::MARK_READ_RPC, [
+                'id' => $notification,
+                'usuario_id' => $this->identity($request)['user_id'],
+            ], $this->accessToken($request));
+        } catch (AcademicGatewayException $exception) {
+            return back()->with('notification_error', $this->friendlyStatus($exception));
+        }
+
+        return back()->with('notification_success', 'La notificación se marcó como leída.');
+    }
+
+    public function markAllAsRead(Request $request): RedirectResponse
+    {
+        try {
+            $this->gateway->invoke(self::MARK_ALL_READ_RPC, [
+                'usuario_id' => $this->identity($request)['user_id'],
+            ], $this->accessToken($request));
+        } catch (AcademicGatewayException $exception) {
+            return back()->with('notification_error', $this->friendlyStatus($exception));
+        }
+
+        return back()->with('notification_success', 'Todas tus notificaciones están al día.');
+    }
+
+    /**
+     * @return array{id: string, title: string, message: string, type: string, priority: string, unread: bool, time: string, icon: string}|null
+     */
+    private function normalize(mixed $value): ?array
+    {
+        if (! is_array($value) || ! is_scalar($value['id'] ?? null) || (string) $value['id'] === '') {
+            return null;
+        }
+
+        $type = trim((string) ($value['tipo'] ?? 'sistema'));
+        $state = trim((string) ($value['estado'] ?? ''));
+        $read = filter_var($value['leida'] ?? false, FILTER_VALIDATE_BOOL) || $state === 'leido';
+        $createdAt = trim((string) ($value['creadoEn'] ?? $value['creado_en'] ?? ''));
+
+        return [
+            'id' => (string) $value['id'],
+            'title' => trim((string) ($value['titulo'] ?? 'Notificación académica')),
+            'message' => trim((string) ($value['mensaje'] ?? 'Tienes una nueva actualización académica.')),
+            'type' => Str::headline($type !== '' ? $type : 'sistema'),
+            'priority' => Str::lower(trim((string) ($value['prioridad'] ?? 'normal'))),
+            'unread' => ! $read,
+            'time' => $this->relativeTime($createdAt),
+            'icon' => $this->icon((string) ($value['iconId'] ?? $value['icon_id'] ?? ''), $type),
+        ];
+    }
+
+    private function relativeTime(string $value): string
+    {
+        if ($value === '') {
+            return 'Hace instantes';
+        }
+
+        try {
+            return Carbon::parse($value)->locale('es')->diffForHumans();
+        } catch (Throwable) {
+            return $value;
+        }
+    }
+
+    private function icon(string $icon, string $type): string
+    {
+        $value = Str::lower($icon.' '.$type);
+
+        return match (true) {
+            Str::contains($value, ['calendar', 'calendario', 'evento']) => 'calendar',
+            Str::contains($value, ['book', 'curso', 'academic', 'tarea']) => 'book',
+            Str::contains($value, ['check', 'aprob', 'success']) => 'check',
+            Str::contains($value, ['alert', 'warning', 'urgente']) => 'alert',
+            default => 'bell',
+        };
+    }
+
+    /** @return array{user_id: string, identifier: string, email: string, role: string} */
+    private function identity(Request $request): array
+    {
+        $session = config('academic-interface.session');
+        $session = is_array($session) ? $session : [];
+
+        return [
+            'user_id' => (string) $request->session()->get((string) ($session['user_id'] ?? ''), ''),
+            'identifier' => (string) $request->session()->get((string) ($session['identifier'] ?? ''), ''),
+            'email' => (string) $request->session()->get((string) ($session['email'] ?? ''), ''),
+            'role' => (string) $request->session()->get((string) ($session['role'] ?? ''), ''),
+        ];
+    }
+
+    /** @param  array{user_id: string, identifier: string, email: string, role: string}  $identity */
+    private function displayName(array $identity): string
+    {
+        $source = $identity['email'] !== '' ? Str::before($identity['email'], '@') : '';
+
+        if ($source === '' || is_numeric($source)) {
+            return 'Estudiante';
+        }
+
+        return Str::of($source)->replace(['.', '_', '-'], ' ')->title()->toString();
+    }
+
+    private function displayRole(string $role): string
+    {
+        return $role === '' ? 'Comunidad académica' : Str::headline(Str::lower($role));
+    }
+
+    private function accessToken(Request $request): string
+    {
+        return (string) $request->session()->get(
+            (string) config('academic-interface.session.access_token'),
+            '',
+        );
+    }
+
+    private function friendlyStatus(AcademicGatewayException $exception): string
+    {
+        return match ($exception->statusCode) {
+            7 => 'No tienes permisos para realizar esta acción.',
+            16 => 'Tu sesión venció. Vuelve a iniciar sesión para continuar.',
+            14 => 'No pudimos conectar con Notificaciones. Inténtalo nuevamente en unos minutos.',
+            default => 'No pudimos completar la operación. Inténtalo nuevamente.',
+        };
+    }
+}
