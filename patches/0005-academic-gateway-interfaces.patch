+
+            return $this->check($label, false, 'El gateway aceptó una consulta que debía rechazar.');
+        } catch (GatewayRpcException $exception) {
+            return $this->check(
+                $label,
+                $exception->isAuthenticationFailure(),
+                "Respuesta gRPC {$exception->statusCode}; se esperaba Unauthenticated (16).",
+            );
+        }
+    }
+
