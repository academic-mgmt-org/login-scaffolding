 class GatewaySessionAuditController extends Controller
 {
+    public function __construct(private readonly GatewayClient $gateway) {}
+
+    public function __invoke(Request $request): View
+    {
+        $accessToken = (string) $request->session()->get((string) config('gateway.session.access_token'), '');
+        $refreshToken = (string) $request->session()->get((string) config('gateway.session.refresh_token'), '');
+        $userId = (string) $request->session()->get((string) config('gateway.session.user_id'), '');
+        $checks = [];
+
+        try {
+            $identity = $this->gateway->validateToken($accessToken);
+            $checks[] = $this->check(
+                'Token emitido válido',
+                $identity['is_valid'],
+                $identity['is_valid'] ? 'ValidateToken confirmó la sesión.' : 'ValidateToken devolvió isValid=false antes del logout.',
+            );
+
+            $this->gateway->recentNotifications($accessToken, $userId, 1);
+            $checks[] = $this->check('Consulta protegida autorizada', true, 'RecentNotifications aceptó el bearer token vigente.');
+
+            $this->gateway->logout($accessToken, $refreshToken);
+            $checks[] = $this->check('Logout remoto', true, 'AuthService/Logout revocó la sesión remota.');
+
+            $revokedIdentity = $this->gateway->validateToken($accessToken);
+            $checks[] = $this->check(
+                'Token revocado',
+                ! $revokedIdentity['is_valid'],
+                $revokedIdentity['is_valid'] ? 'ValidateToken todavía considera válido el token.' : 'ValidateToken devolvió isValid=false.',
+            );
+
+            $checks[] = $this->expectAuthenticationRejection(
+                'Rechazo del token revocado',
+                fn () => $this->gateway->recentNotifications($accessToken, $userId, 1),
+            );
+
+            $checks[] = $this->expectAuthenticationRejection(
+                'Rechazo sin login',
+                fn () => $this->gateway->unreadNotifications('', '', 1),
+            );
+        } catch (GatewayRpcException $exception) {
+            $checks[] = $this->check(
+                'Flujo de sesión interrumpido',
+                false,
+                "{$exception->rpc} respondió gRPC {$exception->statusCode}: {$exception->getMessage()}",
+            );
+        } finally {
+            Auth::guard('web')->logout();
+            $request->session()->invalidate();
+            $request->session()->regenerateToken();
+        }
+
+        return view('notifications.session-audit', [
+            'checks' => $checks,
+            'allPassed' => collect($checks)->every(fn (array $check): bool => $check['passed']),
+        ]);
+    }
+
     /**
