 namespace App\Http\Controllers;
 
+use App\Contracts\GatewayClient;
+use App\Exceptions\GatewayRpcException;
+use Illuminate\Http\RedirectResponse;
 use Illuminate\Http\Request;
+use Illuminate\Support\Arr;
+use Illuminate\Support\Facades\Log;
+use Illuminate\View\View;
 
 class GatewayFlowController extends Controller
 {
-    //
+    public function __construct(private readonly GatewayClient $gateway) {}
+
+    public function show(Request $request, string $flow): View
+    {
+        $definition = $this->flow($flow);
+        $context = $this->context($request);
+        $actions = [];
+
+        foreach ($definition['actions'] as $key => $action) {
+            $action['payload'] = $this->resolvePayload($action['payload'], $context);
+            $action['completed_at'] = $request->session()->get("gateway.flow.completed.{$flow}.{$key}");
+            $actions[$key] = $action;
+        }
+
+        return view('flows.show', [
+            'flowKey' => $flow,
+            'flow' => $definition,
+            'actions' => $actions,
+            'context' => $context,
+            'lastResult' => $request->session()->get('gateway.flow.last_result'),
+        ]);
+    }
+
+    public function execute(Request $request, string $flow, string $action): RedirectResponse
+    {
+        $definition = $this->flow($flow);
+        abort_unless(isset($definition['actions'][$action]), 404);
+
+        $step = $definition['actions'][$action];
+        $context = $this->context($request);
+        $expectedPayload = $this->resolvePayload($step['payload'], $context);
+        $types = $step['types'];
+        $rules = [];
+
+        foreach (array_keys($expectedPayload) as $field) {
+            $type = $types[$field] ?? 'string';
+            $rules["payload.{$field}"] = match ($type) {
+                'boolean' => ['present', 'boolean'],
+                'integer' => ['required', 'integer'],
+                'number' => ['required', 'numeric'],
+                'email' => ['required', 'email:rfc', 'max:255'],
+                'url' => ['required', 'url:http,https', 'max:2048'],
+                'date' => ['required', 'date_format:Y-m-d'],
+                default => ['required', 'string', 'max:5000'],
+            };
+        }
+
+        /** @var array{payload?: array<string, mixed>} $validated */
+        $validated = $request->validate($rules);
+        $submitted = $validated['payload'] ?? [];
+        $payload = [];
+
+        foreach ($expectedPayload as $field => $default) {
+            $value = $submitted[$field] ?? $default;
+            $payload[$field] = match ($types[$field] ?? 'string') {
+                'boolean' => filter_var($value, FILTER_VALIDATE_BOOL),
+                'integer' => (int) $value,
+                'number' => (float) $value,
+                default => trim((string) $value),
+            };
+        }
+
+        $authenticated = $step['authenticated'] ?? $definition['authenticated'];
+        $accessToken = $authenticated
+            ? (string) $request->session()->get((string) config('gateway.session.access_token'), '')
+            : '';
+
+        if ($authenticated && $accessToken === '') {
+            return redirect()->route('login')->withErrors([
+                'email' => 'La sesión del gateway expiró. Inicia sesión nuevamente.',
+            ]);
+        }
+
+        try {
+            $result = $this->gateway->invoke($step['rpc'], $payload, $accessToken);
+        } catch (GatewayRpcException $exception) {
+            Log::warning('Academic gateway flow action failed.', [
+                'flow' => $flow,
+                'action' => $action,
+                'rpc' => $exception->rpc,
+                'status_code' => $exception->statusCode,
+            ]);
+
+            return back()
+                ->withInput()
+                ->with('gateway_flow_error', [
+                    'flow' => $flow,
+                    'action' => $action,
+                    'rpc' => $exception->rpc,
+                    'status' => $exception->statusCode,
+                    'message' => $this->friendlyStatus($exception),
+                ]);
+        }
+
+        foreach ($step['payload'] as $field => $template) {
+            if (is_string($template) && preg_match('/^\{([a-z0-9_]+)\}$/', $template, $matches) === 1) {
+                $context[$matches[1]] = $payload[$field];
+            }
+        }
+
+        foreach ($step['capture'] as $contextKey => $path) {
+            $captured = data_get($result, $path);
+
+            if (is_scalar($captured) && (string) $captured !== '') {
+                $context[$contextKey] = $captured;
+            }
+        }
+
+        if (($context['enrollment_code'] ?? '') === '' && ($context['enrollment_id'] ?? '') !== '') {
+            $context['enrollment_code'] = $context['enrollment_id'];
+        }
+
+        $request->session()->put([
+            'gateway.flow.context' => $context,
+            "gateway.flow.completed.{$flow}.{$action}" => now()->toIso8601String(),
+            'gateway.flow.last_result' => [
+                'flow' => $flow,
+                'action' => $action,
+                'title' => $step['title'],
+                'rpc' => $step['rpc'],
+                'payload' => $this->redact($payload),
+                'response' => $result,
+            ],
+        ]);
+
+        return back()->with('gateway_flow_success', "Bloque {$step['block']} ejecutado correctamente.");
+    }
+
+    public function reset(Request $request): RedirectResponse
+    {
+        $request->session()->forget([
+            'gateway.flow.context',
+            'gateway.flow.completed',
+            'gateway.flow.last_result',
+        ]);
+
+        return redirect()->route('dashboard')->with('gateway_flow_success', 'El contexto de los flujos fue reiniciado.');
+    }
+
+    /** @return array<string, mixed> */
+    private function flow(string $flow): array
+    {
+        $flows = config('gateway-flows.flows');
+        abort_unless(is_array($flows) && isset($flows[$flow]) && is_array($flows[$flow]), 404);
+
+        /** @var array<string, mixed> $definition */
+        $definition = $flows[$flow];
+
+        return $definition;
+    }
+
+    /** @return array<string, bool|float|int|string> */
+    private function context(Request $request): array
+    {
+        $defaults = config('gateway-flows.context_defaults');
+        $defaults = is_array($defaults) ? $defaults : [];
+        $stored = $request->session()->get('gateway.flow.context', []);
+        $stored = is_array($stored) ? $stored : [];
+        $context = array_merge($defaults, $stored);
+
+        if (($context['flow_id'] ?? '') === '') {
+            $context['flow_id'] = now('UTC')->format('YmdHis');
+            $request->session()->put('gateway.flow.context', $context);
+        }
+
+        /** @var array<string, bool|float|int|string> $context */
+        return $context;
+    }
+
+    /**
+     * @param  array<string, mixed>  $payload
+     * @param  array<string, bool|float|int|string>  $context
+     * @return array<string, mixed>
+     */
+    private function resolvePayload(array $payload, array $context): array
+    {
+        $replace = [];
+
+        foreach ($context as $key => $value) {
+            $replace['{'.$key.'}'] = (string) $value;
+        }
+
+        return Arr::map($payload, static fn (mixed $value): mixed => is_string($value)
+            ? strtr($value, $replace)
+            : $value);
+    }
+
+    /**
+     * @param  array<string, mixed>  $payload
+     * @return array<string, mixed>
+     */
+    private function redact(array $payload): array
+    {
+        foreach (['password', 'temporary_password', 'newPassword', 'token'] as $sensitive) {
+            if (array_key_exists($sensitive, $payload)) {
+                $payload[$sensitive] = '[redacted]';
+            }
+        }
+
+        return $payload;
+    }
+
+    private function friendlyStatus(GatewayRpcException $exception): string
+    {
+        $label = match ($exception->statusCode) {
+            3 => 'Argumento inválido',
+            5 => 'Registro no encontrado',
+            6 => 'El registro ya existe',
+            7 => 'Permiso denegado para el rol actual',
+            12 => 'RPC no publicado por el gateway',
+            14 => 'Servicio temporalmente no disponible',
+            16 => 'Sesión no autenticada o expirada',
+            default => 'El gateway rechazó la operación',
+        };
+
+        return "{$label}. Detalle: {$exception->getMessage()}";
+    }
 }
