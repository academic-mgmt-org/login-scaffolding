diff --git a/app/Support/AcademicModules.php b/app/Support/AcademicModules.php
new file mode 100644
index 0000000..55c9287
--- /dev/null
+++ b/app/Support/AcademicModules.php
@@ -0,0 +1,88 @@
+<?php
+
+namespace App\Support;
+
+use RuntimeException;
+
+final class AcademicModules
+{
+    /** @return array<string, array<string, mixed>> */
+    public static function discover(): array
+    {
+        $modules = [];
+
+        self::add($modules, config('academic-module'));
+
+        $paths = glob(config_path('academic-modules/*.php')) ?: [];
+        sort($paths, SORT_STRING);
+
+        foreach ($paths as $path) {
+            self::add($modules, require $path);
+        }
+
+        return $modules;
+    }
+
+    /** @return array<string, array<string, mixed>> */
+    public static function all(): array
+    {
+        $modules = config('academic-modules');
+
+        return is_array($modules) ? $modules : self::discover();
+    }
+
+    /** @return array<string, mixed>|null */
+    public static function find(string $keyOrSlug): ?array
+    {
+        foreach (self::all() as $key => $module) {
+            if ($key === $keyOrSlug || ($module['slug'] ?? null) === $keyOrSlug) {
+                return $module;
+            }
+        }
+
+        return null;
+    }
+
+    /** @return array<string, mixed>|null */
+    public static function default(): ?array
+    {
+        $modules = self::all();
+
+        if (isset($modules['academico-login'])) {
+            return $modules['academico-login'];
+        }
+
+        $module = reset($modules);
+
+        return is_array($module) ? $module : null;
+    }
+
+    /**
+     * @param  array<string, array<string, mixed>>  $modules
+     */
+    private static function add(array &$modules, mixed $module): void
+    {
+        if (! is_array($module) || ! isset($module['key'], $module['slug'], $module['actions'])) {
+            return;
+        }
+
+        $key = (string) $module['key'];
+        $slug = trim((string) $module['slug'], '/');
+
+        if (preg_match('/^academico-[a-z0-9-]+$/', $key) !== 1
+            || preg_match('/^[a-z0-9-]+$/', $slug) !== 1
+            || ! is_array($module['actions'])) {
+            throw new RuntimeException("Invalid academic interface module: {$key}.");
+        }
+
+        foreach ($modules as $installedKey => $installed) {
+            if ($installedKey !== $key && ($installed['slug'] ?? null) === $slug) {
+                throw new RuntimeException("Academic module slug already registered: {$slug}.");
+            }
+        }
+
+        $module['key'] = $key;
+        $module['slug'] = $slug;
+        $modules[$key] = $module;
+    }
+}
